# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/crm_dev"
DIRECT_DATABASE_URL="postgresql://user:password@localhost:5432/crm_dev"

# ─── Auth (Auth.js v5) ────────────────────────────────────────────────────────
# Gerar: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Email (Resend) ──────────────────────────────────────────────────────────
AUTH_RESEND_KEY=""
EMAIL_FROM="CRM <noreply@seudominio.com>"

# ─── AI (OpenRouter) ────────────────────────────────────────────────────────
OPENROUTER_API_KEY=""

# ─── Embeddings (RAG do catálogo de cursos) ─────────────────────────────────
# Provider compatível-OpenAI (OpenRouter NÃO serve embeddings). Sem chave, o
# catálogo funciona só na busca estruturada (área/preço/texto).
EMBEDDINGS_API_KEY=""
# EMBEDDINGS_BASE_URL="https://api.openai.com/v1"
# EMBEDDINGS_MODEL="text-embedding-3-small"

# ─── Cron (acompanhamento de leads) ─────────────────────────────────────────
# Gerar: openssl rand -hex 32
CRON_SECRET=""

# ─── Transcrição (OpenAI Whisper) ────────────────────────────────────────────
OPENAI_API_KEY=""

# ─── Storage (Cloudflare R2 ou AWS S3) ───────────────────────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="crm-storage"
R2_PUBLIC_URL=""

# ─── Redis (BullMQ) ──────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── WhatsApp (Evolution API) ────────────────────────────────────────────────
EVOLUTION_API_URL=""      # ex: https://evolution.seudominio.com
EVOLUTION_API_KEY=""      # Global API Key configurada na Evolution API

# ─── WhatsApp (Z-API) ────────────────────────────────────────────────────────
# Painel Z-API → Instância. NUNCA comitar valores reais (usar env do deploy).
ZAPI_INSTANCE_ID=""       # ID da instância (também usado como instanceName no DB)
ZAPI_INSTANCE_TOKEN=""    # Token da instância (vai na URL de envio)
ZAPI_CLIENT_TOKEN=""      # Token de segurança da conta (header Client-Token)
ZAPI_BASE_URL=""          # opcional; default https://api.z-api.io

# ─── Chatwoot (espelho de conversas) ─────────────────────────────────────────
# Inbox do tipo "API" no Chatwoot. Forwarder é no-op enquanto vazio.
CHATWOOT_URL=""           # ex: https://chatwoot.seudominio.com.br
CHATWOOT_ACCOUNT_ID=""    # id numérico da conta
CHATWOOT_INBOX_ID=""      # id do inbox tipo API
CHATWOOT_API_TOKEN=""     # access token de agente/bot (header api_access_token)
# Hand-off (gatilho 1): Chatwoot chama /api/webhooks/chatwoot?secret=... quando
# um humano responde, pausando a IA naquela conversa.
CHATWOOT_WEBHOOK_SECRET="" # segredo na URL/header do webhook do Chatwoot
CHATWOOT_TENANT_SLUG=""    # slug do tenant dono desta conta Chatwoot

# ─── Sentry (monitoramento de erros) ─────────────────────────────────────────
# SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_DSN=""

# ─── Testes E2E (Playwright) ─────────────────────────────────────────────────
